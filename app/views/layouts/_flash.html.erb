<% flash.each do |key, value| %>
  <% if value.is_a? Array %>
    <% value.each do |element| %>
      <div class="<%= flash_class(key) || "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900" %>">
        <%= element %>
      </div>
    <% end %>
  <% else %>
    <div class="<%= flash_class(key) || "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900" %>" >
      <%= value %>
    </div>
  <% end %>
<% end %>
